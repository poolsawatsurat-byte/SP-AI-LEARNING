{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["docs/typescript-guidelines.md"],
  "mcp":{
    "next-devtools-mcp":{
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "formatter": true,
  "lsp": true,
  "permission": {
    "bash": {
      "git add *": "ask",
      "git commit *": "ask",
      "rm *": "ask"
    }
  }
}